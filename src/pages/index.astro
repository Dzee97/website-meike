---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import EntryCard from "../components/EntryCard.astro";

const about = await getEntry("pages", "about");

const experience = await getCollection("experience");
experience.sort((a, b) => a.data.order - b.data.order);

const projects = await getCollection("projects");
projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Meike Valk"
  description="Personal career website"
>
  <header>
    <h1>Meike Valk</h1>
    <p>Short professional tagline here</p>

    <nav>
      <a href="#about">About</a>
      <a href="#experience">Experience</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <section id="about">
      <h2>{about?.data.title}</h2>
      {about && <p>{about.body}</p>}
    </section>

    <section id="experience">
      <h2>Experience</h2>

      {experience.map((item) => (
        <EntryCard
          title={item.data.title}
          subtitle={`${item.data.organization} · ${item.data.period}`}
          description={item.body}
        />
      ))}
    </section>

    <section id="projects">
      <h2>Projects</h2>

      {projects.map((item) => (
        <EntryCard
          title={item.data.title}
          subtitle={item.data.subtitle}
          description={item.body}
        />
      ))}
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>
        <a href="mailto:her-email@example.com">her-email@example.com</a>
      </p>
      <p>
        <a href="https://www.linkedin.com/in/example">LinkedIn</a>
      </p>
    </section>
  </main>
</BaseLayout>
